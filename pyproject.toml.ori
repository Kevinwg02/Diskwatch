[build-system]
requires = ["setuptools>=69"]
build-backend = "setuptools.build_meta"

[project]
name = "diskwatch"
version = "0.1.0"
description = "Interactive disk usage analyzer"
readme = "README.md"
requires-python = ">=3.10"

authors = [
  {name = "Kenemi"}
]

dependencies = [
    "psutil",
    "rich",
    "textual",
]

[project.scripts]
diskwatch = "diskwatch.diskwatch:main"

[tool.setuptools]
package-dir = {"" = "src"}

[tool.setuptools.packages.find]
where = ["src"]
